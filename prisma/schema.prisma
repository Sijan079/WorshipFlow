generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum ServiceStatus {
  DRAFT
  READY
  ARCHIVED
}

enum ServiceVariant {
  STANDARD
  EXTENDED
}

enum AssignedMinistry {
  LEADERS
  YOUTH
  MENS
  LADIES
  MIXED
}

enum ServiceTemplateType {
  REGULAR
  FIRST_SUNDAY
}

enum PledgeType {
  PLEDGE_OF_FAITH
  COVENANT
}

enum ServiceServantRole {
  CALL_TO_WORSHIP
  EMCEE
  SCRIPTURE_READER
  SERMON_SPEAKER
  OFFERING
  PLEDGE_READER
}

enum ServiceHymnalRole {
  HYMN_OF_PREPARATION
  HYMN_OF_RESPONSE
  SONG_OF_HYMNS
}

enum BlockType {
  CALL_TO_WORSHIP
  PRAISE_AND_WORSHIP
  MC
  AWIT_NG_HIMNO
  TIPAN_PAHAYAG
  AWIT_NG_PAKIKINIG
  SCRIPTURE_READING
  SERMON
  AWIT_NG_PAGTUGON
  OFFERING
  FLOWERS_FOR_THE_LORD
  DETAILS
}

enum SongRole {
  OPENING
  PRAISE
  TRANSITION
  RESPONSE
  SPECIAL
  CUSTOM
}

enum AssetType {
  SCREENSHOT
  DOCX
  PDF
  IMAGE
  VIDEO
  EXPORT
  OTHER
}

enum JobType {
  TRANSPOSE
  FREESHOW_GENERATE
  CAPTION_GENERATE
  BACKGROUND_IMAGE_GENERATE
  BACKGROUND_VIDEO_GENERATE
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum OutputType {
  FREESHOW
  DOCX
  PDF
  CAPTION_PACK
  BACKGROUND_IMAGE
  BACKGROUND_VIDEO
  ZIP
}

model Workspace {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services  WorshipService[]
  songs     Song[]
  tagPresets SongTagPreset[]
  automationJobs AutomationJob[]
  generatedOutputs GeneratedOutput[]
}

model PapInboxScreenshot {
  id          String   @id @default(uuid())
  batchId     String
  batchIndex  Int
  batchTotal  Int
  fileName    String
  filePath    String
  mimeType    String
  size        Int
  note        String?
  deviceName  String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([batchId, createdAt])
  @@map("PAPInboxScreenshot")
}

model WorshipService {
  id            String         @id @default(uuid())
  workspaceId   String
  serviceDate   DateTime
  ministryName  String
  assignedMinistry AssignedMinistry?
  sermonVerse   String?
  theme         String?
  status        ServiceStatus  @default(DRAFT)
  serviceVariant ServiceVariant @default(STANDARD)
  templateType  ServiceTemplateType @default(REGULAR)
  pledgeType    PledgeType?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  blocks        WorshipServiceBlock[]
  songs         WorshipServiceSong[]
  details       WorshipServiceDetail[]
  bibleVerses   ServiceBibleVerse[]
  servantAssignments ServiceServantAssignment[]
  hymnals       ServiceHymnal[]
  assets        ServiceAsset[]
  jobs          AutomationJob[]
  outputs       GeneratedOutput[]

  @@index([workspaceId, serviceDate])
}

model WorshipServiceBlock {
  id          String     @id @default(uuid())
  serviceId   String
  blockType   BlockType
  order       Int

  service     WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  people      BlockPerson[]
  songs       WorshipServiceSong[]
  details     WorshipServiceDetail[]

  createdAt   DateTime @default(now())
}

model BlockPerson {
  id          String   @id @default(uuid())
  blockId     String

  personName  String
  personTitle String?

  order       Int @default(0)

  block       WorshipServiceBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

model Song {
  id           String   @id @default(uuid())
  workspaceId  String
  title        String
  author       String?
  defaultKey   String?
  bpm          Int?
  language     String?
  isOriginal   Boolean  @default(false)

  createdAt    DateTime @default(now())

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  files        SongFile[]
  serviceSongs WorshipServiceSong[]

  @@index([workspaceId, title])
}

model SongFile {
  id          String   @id @default(uuid())
  songId      String

  fileName    String
  filePath    String
  version     String?

  createdAt   DateTime @default(now())

  song        Song @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model SongTagPreset {
  id        String   @id @default(uuid())
  workspaceId String
  label     String
  token     String
  color     String
  order     Int      @default(0)
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, token])
  @@index([order])
  @@index([workspaceId, order])
}

model WorshipServiceSong {
  id          String @id @default(uuid())

  serviceId   String
  blockId     String
  songId      String

  order       Int
  songRole    SongRole

  pageRef     String?

  service     WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  block       WorshipServiceBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  song        Song @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model WorshipServiceDetail {
  id          String @id @default(uuid())

  serviceId   String
  blockId     String?
  key         String
  value       String

  service     WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  block       WorshipServiceBlock? @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

model ServiceBibleVerse {
  id        String @id @default(uuid())
  serviceId String
  verse     String
  order     Int    @default(0)

  service   WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, order])
}

model ServiceServantAssignment {
  id         String @id @default(uuid())
  serviceId  String
  role       ServiceServantRole
  personName String

  service    WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, role])
  @@index([serviceId])
}

model ServiceHymnal {
  id        String @id @default(uuid())
  serviceId String
  role      ServiceHymnalRole
  title     String

  service   WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, role])
  @@index([serviceId])
}

model ServiceAsset {
  id          String @id @default(uuid())

  serviceId   String
  type        AssetType

  fileName    String
  filePath    String

  createdAt   DateTime @default(now())

  service     WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model AutomationJob {
    id          String @id @default(uuid())

    workspaceId String
    serviceId   String?
    jobType     JobType
    status      JobStatus @default(QUEUED)

  inputJson   Json?
  outputJson  Json?

  createdAt   DateTime @default(now())
  completedAt DateTime?

    workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    service     WorshipService? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    outputs     GeneratedOutput[]

    @@index([workspaceId, createdAt])
  }

model GeneratedOutput {
    id          String @id @default(uuid())

    workspaceId String
    serviceId   String?
    jobId       String?

  type        OutputType
  filePath    String

  createdAt   DateTime @default(now())

    workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    service     WorshipService? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    job         AutomationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

    @@index([workspaceId, createdAt])
  }
