DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?sslmode=require"

# Optional but recommended for Prisma migrations in deployment.
# Use the direct Supabase database connection, not the transaction pooler.
DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Optional login gate. Leave unset locally; set in Vercel to password-protect the app.
APP_ACCESS_USER=""
APP_ACCESS_PASSWORD=""
APP_ACCESS_SESSION_SECRET=""

# Optional AI cleanup for Song Formatter/extractor fallback.
OPENAI_API_KEY=""
OPENAI_EXTRACTOR_MODEL="gpt-4.1-mini"

# Optional AI media generation for Media Tools background generation.
# Images use OpenAI. Video generation is disabled until a new provider is selected.
# Leave provider keys unset to use local mock outputs during development.
OPENAI_BACKGROUND_IMAGE_MODEL="gpt-image-1"
OPENAI_BACKGROUND_IMAGE_ESTIMATED_COST_USD="0.04"
MEDIA_GENERATION_IMAGE_HOURLY_LIMIT="5"
MEDIA_GENERATION_IMAGE_DAILY_LIMIT="25"

# Phone Transfer / PAP
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_PAP_PUBLIC_URL="http://localhost:3000"

# Supabase
# Use Supabase Postgres by setting DATABASE_URL above to the pooled connection string.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Server-only private storage for temporary PAP uploads and generated outputs.
SUPABASE_URL=""
SUPABASE_SECRET_KEY=""
SUPABASE_PRIVATE_BUCKET="worship-flow-private"
